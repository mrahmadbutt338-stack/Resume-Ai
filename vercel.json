{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "framework": "express"
    }
  },
  "rewrites": [
    {
      "source": "/api/backend/:match*",
      "destination": "/backend/:match*"
    },
    {
      "source": "/:match*",
      "destination": "/frontend/:match*"
    }
  ]
}
